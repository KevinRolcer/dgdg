APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_FORCE_HTTPS=false
PHP_INCLUDE_PATH_PREFIX=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file


BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax


SECURITY_TRUSTED_CORS_ORIGINS=http://localhost,http://127.0.0.1,http://segob.test
SECURITY_CSP_REPORT_ONLY=false
SECURITY_CSP_REPORT_URI=
SECURITY_CSP_ALLOW_UNSAFE_INLINE_SCRIPTS=true
SECURITY_CSP_ALLOW_UNSAFE_EVAL_SCRIPTS=true
SECURITY_CSP_SCRIPT_SRC=https://cdnjs.cloudflare.com,https://cdn.jsdelivr.net,https://unpkg.com,https://static.cloudflareinsights.com
SECURITY_CSP_STYLE_SRC=https://fonts.googleapis.com,https://cdnjs.cloudflare.com,https://cdn.jsdelivr.net
SECURITY_CSP_IMG_SRC=https://*.openstreetmap.org
SECURITY_CSP_FONT_SRC=https://fonts.gstatic.com,https://cdnjs.cloudflare.com,https://cdn.jsdelivr.net
SECURITY_CSP_CONNECT_SRC=https://static.cloudflareinsights.com,https://cdn.jsdelivr.net,https://cdnjs.cloudflare.com,https://unpkg.com,https://nominatim.openstreetmap.org

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
DB_QUEUE_RETRY_AFTER=15000

TEMPORARY_MODULE_PYTHON=

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

SHARED_UPLOADS_PATH=


WHATSAPP_CHATS_MASTER_KEY_BASE64=

WHATSAPP_CHATS_TOTP_ISSUER=
WHATSAPP_CHATS_TOTP_HOLDER=

WHATSAPP_CHATS_UNLOCK_TTL=30

WHATSAPP_CHATS_DISK=whatsapp_chats

WHATSAPP_CHATS_USE_SHARED=false

WHATSAPP_CHATS_MAX_UPLOAD_MB=768

WHATSAPP_CHATS_TXT_PREVIEW_MAX_FILE_MB=15
WHATSAPP_CHATS_TXT_PREVIEW_MAX_MESSAGES=5000

WHATSAPP_CHATS_RETENTION_DAYS=0

WHATSAPP_CHATS_BACKUP_PATH=

VITE_APP_NAME="${APP_NAME}"


