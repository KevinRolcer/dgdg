APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_FORCE_HTTPS=false
PHP_INCLUDE_PATH_PREFIX=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# file = sin tabla sessions | database = ejecutar migración create_sessions_table
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

# Seguridad HTTP / CORS / CSP
# En producción define orígenes exactos, separados por coma, por ejemplo:
# SECURITY_TRUSTED_CORS_ORIGINS=https://segob.puebla.gob.mx,https://admin.segob.puebla.gob.mx
SECURITY_TRUSTED_CORS_ORIGINS=http://localhost,http://127.0.0.1,http://segob.test
SECURITY_CSP_REPORT_ONLY=false
SECURITY_CSP_REPORT_URI=
SECURITY_CSP_ALLOW_UNSAFE_INLINE_SCRIPTS=true
SECURITY_CSP_ALLOW_UNSAFE_EVAL_SCRIPTS=true
SECURITY_CSP_SCRIPT_SRC=https://cdnjs.cloudflare.com,https://cdn.jsdelivr.net,https://unpkg.com,https://static.cloudflareinsights.com
SECURITY_CSP_STYLE_SRC=https://fonts.googleapis.com,https://cdnjs.cloudflare.com,https://cdn.jsdelivr.net
SECURITY_CSP_IMG_SRC=https://*.openstreetmap.org
SECURITY_CSP_FONT_SRC=https://fonts.gstatic.com,https://cdnjs.cloudflare.com,https://cdn.jsdelivr.net
SECURITY_CSP_CONNECT_SRC=https://static.cloudflareinsights.com,https://cdn.jsdelivr.net,https://cdnjs.cloudflare.com,https://unpkg.com,https://nominatim.openstreetmap.org

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# database = requiere worker: composer run queue-work (o composer run dev). Ver docs/COLA_EXPORTACIONES.md
QUEUE_CONNECTION=database
# Segundos antes de volver a tomar un job reservado en `jobs` (debe ser > que el job más largo; importación WhatsApp ≈ 4 h).
DB_QUEUE_RETRY_AFTER=15000

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Ruta absoluta fuera de public/ (HostGator, NFS, etc.). Usada por discos secure_shared y, si activas WhatsApp shared, por whatsapp_chats.
SHARED_UPLOADS_PATH=

# -----------------------------------------------------------------------------
# Chats WhatsApp (módulo sensible /admin/whatsapp-chats) — revisar en producción
# Documentación: docs/WHATSAPP_CHATS_SECURITY.md
# Cron: php artisan schedule:run (incluye whatsapp-chats:prune y whatsapp-chats:backup)
# -----------------------------------------------------------------------------

# PRODUCCIÓN: definir siempre. 32 bytes aleatorios en base64:
#   php -r "echo base64_encode(random_bytes(32)), PHP_EOL;"
# Si queda vacío, la KEK se deriva de APP_KEY (solo aceptable en local; malo si rotas APP_KEY).
WHATSAPP_CHATS_MASTER_KEY_BASE64=

# Google Authenticator (TOTP). Issuer: nombre en la app; HOLDER: opcional, sustituye al email como etiqueta.
WHATSAPP_CHATS_TOTP_ISSUER=
WHATSAPP_CHATS_TOTP_HOLDER=

# Legado (antes step-up por contraseña); el flujo actual usa TOTP. Opcional.
WHATSAPP_CHATS_UNLOCK_TTL=30

# Disco Laravel: por defecto "whatsapp_chats" → storage/app/whatsapp_chats_private
WHATSAPP_CHATS_DISK=whatsapp_chats

# true = guardar chats en {SHARED_UPLOADS_PATH}/whatsapp_chats_private (recomendado en producción para no llenar el proyecto)
WHATSAPP_CHATS_USE_SHARED=false

# Tamaño máximo del ZIP de importación (MB). Laravel usa este valor; PHP y el servidor web deben permitir al menos lo mismo (upload_max_filesize, post_max_size, client_max_body_size).
WHATSAPP_CHATS_MAX_UPLOAD_MB=768

# Vista previa web del _chat.txt: límites para no colgar el navegador (memoria / STATUS_ACCESS_VIOLATION).
WHATSAPP_CHATS_TXT_PREVIEW_MAX_FILE_MB=15
WHATSAPP_CHATS_TXT_PREVIEW_MAX_MESSAGES=5000

# Máximo de archivos por importación por carpeta (export descomprimido).
# WHATSAPP_FOLDER_IMPORT_MAX_FILES=25000

# Retención automática (comando whatsapp-chats:prune). 0 = desactivado.
WHATSAPP_CHATS_RETENTION_DAYS=0

# Carpeta de ZIP de respaldo (whatsapp-chats:backup). Vacío = storage/app/backups/whatsapp_chats
WHATSAPP_CHATS_BACKUP_PATH=

VITE_APP_NAME="${APP_NAME}"

# Mesas de Paz: meta semanal = total_municipios × dias (5). Vacío = 217 (1085 mesas). 0 = usar conteo tabla municipios.
# MESAS_PAZ_TOTAL_MUNICIPIOS=
# MESAS_PAZ_DIAS_LABORALES=5
